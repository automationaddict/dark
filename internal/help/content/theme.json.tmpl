{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "{{.Fg}}",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "{{.Accent}}",
    "bold": true
  },
  "h1": {
    "prefix": "",
    "suffix": "",
    "color": "{{.Accent}}",
    "bold": true
  },
  "h2": {
    "prefix": "",
    "color": "{{.Accent}}",
    "bold": true
  },
  "h3": {
    "prefix": "",
    "color": "{{.Accent}}",
    "bold": true
  },
  "h4": {
    "prefix": "",
    "color": "{{.Accent}}"
  },
  "h5": {
    "prefix": "",
    "color": "{{.Accent}}"
  },
  "h6": {
    "prefix": "",
    "color": "{{.Accent}}"
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "{{.Border}}",
    "format": "\n────────\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "{{.Accent}}",
    "underline": true
  },
  "link_text": {
    "color": "{{.Accent}}",
    "bold": true
  },
  "image": {
    "color": "{{.Accent}}",
    "underline": true
  },
  "image_text": {
    "color": "{{.Dim}}",
    "format": "Image: {{"{{"}}.text{{"}}"}} →"
  },
  "code": {
    "color": "{{.Gold}}"
  },
  "code_block": {
    "color": "{{.Fg}}",
    "margin": 2,
    "chroma": {
      "text": { "color": "{{.Fg}}" },
      "error": { "color": "{{.Red}}" },
      "comment": { "color": "{{.Dim}}", "italic": true },
      "comment_preproc": { "color": "{{.Dim}}" },
      "keyword": { "color": "{{.Accent}}", "bold": true },
      "keyword_reserved": { "color": "{{.Accent}}", "bold": true },
      "keyword_namespace": { "color": "{{.Accent}}", "bold": true },
      "keyword_type": { "color": "{{.Accent}}" },
      "operator": { "color": "{{.Fg}}" },
      "punctuation": { "color": "{{.Fg}}" },
      "name": { "color": "{{.Fg}}" },
      "name_builtin": { "color": "{{.Accent}}" },
      "name_tag": { "color": "{{.Accent}}" },
      "name_attribute": { "color": "{{.Accent}}" },
      "name_class": { "color": "{{.Accent}}", "bold": true },
      "name_constant": { "color": "{{.Gold}}" },
      "name_decorator": { "color": "{{.Accent}}" },
      "name_exception": { "color": "{{.Red}}" },
      "name_function": { "color": "{{.Accent}}" },
      "name_other": { "color": "{{.Fg}}" },
      "literal": { "color": "{{.Gold}}" },
      "literal_number": { "color": "{{.Gold}}" },
      "literal_string": { "color": "{{.Green}}" },
      "literal_string_escape": { "color": "{{.Green}}", "bold": true },
      "generic_deleted": { "color": "{{.Red}}" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "{{.Green}}" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "{{.Accent}}" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}
